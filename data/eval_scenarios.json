        "/var/lib/postgresql/15/main/pg_wal/00000001000001000000000F": "(active WAL, 16 MB)\n",
        "/var/lib/postgresql/15/wal_archive/00000001000001000000000A": "(archived 1 GB)\n",
        "/var/lib/postgresql/15/wal_archive/00000001000001000000000B": "(archived 1 GB)\n",
        "/var/lib/postgresql/15/wal_archive/00000001000001000000000C": "(archived 1 GB)\n"
